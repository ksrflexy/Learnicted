@model Learnicted.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    // Progress null ise hata vermemesi için güvenli bir referans alalım
    var progressObj = Model.Progress;
}

<div class="learnicted-dashboard container py-4">
    @if (progressObj == null || string.IsNullOrEmpty(progressObj.SelectedCourse))
    {
        <div id="onboarding-screen" class="d-flex flex-column align-items-center justify-content-center text-center animate__animated animate__fadeIn" style="min-height: 80vh;">
            <div class="glass-card p-5 shadow-lg" style="max-width: 600px; border-radius: 35px; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1);">
                <div class="mb-4 pulse-icon">
                    <i class="bi bi-rocket-takeoff-fill" style="font-size: 5rem; color: var(--accent);"></i>
                </div>
                <h1 class="display-6 fw-bold text-white mb-3">Geleceği İnşa Et!</h1>
                <p class="text-white-50 mb-4">Sana özel AI destekli müfredatını oluşturmak için tek bir adım kaldı.</p>
                <button class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-orange" style="background: var(--accent); border: none;" onclick="startLearningFlow()">
                    <i class="bi bi-magic me-2"></i> Eğitimi Oluşturmaya Başla
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="animate__animated animate__fadeIn">
            <div class="row mb-5">
                <div class="col-12 glass-card p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="text-white fw-bold mb-0">@progressObj.SelectedCourse</h2>
                        <span class="text-white-50">Öğrenme Yolculuğun Başladı!</span>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="stat-box text-center p-2 px-3 bg-dark bg-opacity-25 rounded-4">
                            <small class="text-white-50 d-block" style="font-size: 0.7rem;">SERİ</small>
                            <span class="text-danger fw-bold">🔥 @progressObj.DailyStreak</span>
                        </div>
                        <div class="stat-box text-center p-2 px-3 bg-dark bg-opacity-25 rounded-4">
                            <small class="text-white-50 d-block" style="font-size: 0.7rem;">XP</small>
                            <span class="text-info fw-bold">💎 @progressObj.TotalXP</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="learning-path d-flex flex-column align-items-center gap-4 py-4">
                @for (int i = 1; i <= 5; i++)
                {
                    bool isLocked = i > 1;
                    <div class="unit-node d-flex flex-column align-items-center @(isLocked ? "locked" : "")"
                         onclick="@(isLocked ? "" : $"goToStudy('{progressObj.SelectedCourse}', {i})")">
                        <div class="unit-circle">
                            @if (isLocked)
                            {
                                <i class="bi bi-lock-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-play-fill text-white"></i>
                            }
                        </div>
                        <div class="text-white mt-2 fw-bold">Ünite @i</div>
                    </div>

                    if (i < 5)
                    {
                        <div class="path-connector @(isLocked ? "locked" : "")"></div>
                    }
                }
            </div>
        </div>
    }

    <div id="ai-wizard-modal" class="wizard-overlay" style="display: none;">
        <div class="wizard-card position-relative animate__animated animate__zoomIn">
            <button id="wizard-back-btn" class="btn btn-link text-white-50 position-absolute start-0 top-0 mt-3 ms-3" style="display:none;" onclick="goBack()">
                <i class="bi bi-chevron-left"></i> Geri
            </button>
            <div id="step-content"></div>
            <div class="text-center mt-4">
                <button class="btn btn-link text-white-50 btn-sm text-decoration-none" onclick="closeWizard()">Vazgeç</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --accent: #ff6b00;
        --accent-glow: rgba(255, 107, 0, 0.4);
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 25px;
    }

    .unit-circle {
        width: 80px;
        height: 80px;
        background: var(--accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        cursor: pointer;
        border: 6px solid rgba(255,255,255,0.1);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 0 20px var(--accent-glow);
    }

    .unit-node:not(.locked):hover .unit-circle {
        transform: scale(1.15) rotate(5deg);
        box-shadow: 0 0 30px var(--accent);
    }

    .unit-node.locked {
        opacity: 0.6;
        cursor: not-allowed;
    }

        .unit-node.locked .unit-circle {
            background: #334155;
            box-shadow: none;
        }

    .path-connector {
        width: 4px;
        height: 40px;
        background: rgba(255,255,255,0.1);
    }

        .path-connector.locked {
            background: rgba(255,255,255,0.05);
        }

    .wizard-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10,15,28,0.95);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

    .wizard-card {
        width: 95%;
        max-width: 500px;
        padding: 40px;
        background: #1e293b;
        border-radius: 35px;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .wizard-opt {
        width: 100%;
        padding: 18px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        color: white;
        text-align: left;
        margin-bottom: 12px;
        transition: 0.3s;
        font-weight: 600;
    }

        .wizard-opt:hover {
            border-color: var(--accent);
            background: rgba(255,107,0,0.1);
            transform: translateX(8px);
        }

    .pulse-icon {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.05);
            opacity: 0.8;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

@section Scripts {
    <script>
        let stepHistory = [];
        const contentArea = () => document.getElementById('step-content');

        const steps = {
            main: `<h3 class="text-white text-center mb-4">Kategori Seç</h3>
                   <button class="wizard-opt" onclick="nextStep('okul')">🎒 Okul Dersleri</button>
                   <button class="wizard-opt" onclick="nextStep('yazilim')">💻 Yazılım Geliştirme</button>
                   <button class="wizard-opt" onclick="nextStep('dil')">🌐 Yabancı Dil</button>`,
            okul: `<h4 class="text-white text-center mb-4">Kademe</h4>
                   <button class="wizard-opt" onclick="nextStep('ilkokul')">🎒 İlkokul</button>
                   <button class="wizard-opt" onclick="nextStep('ortaokul')">📘 Ortaokul</button>
                   <button class="wizard-opt" onclick="nextStep('lise')">🎓 Lise</button>`,
            dil: `<h4 class="text-white text-center mb-4">Dil Seç</h4>
                  <button class="wizard-opt" onclick="completeWizard('İngilizce')">🇬🇧 İngilizce</button>
                  <button class="wizard-opt" onclick="completeWizard('Almanca')">🇩🇪 Almanca</button>`,
            yazilim: `<h4 class="text-white text-center mb-4">Alan Seç</h4>
                      <button class="wizard-opt" onclick="completeWizard('Python')">🐍 Python</button>
                      <button class="wizard-opt" onclick="completeWizard('Web Geliştirme')">🌐 Web Geliştirme</button>`,
            ilkokul: generateGrades(1, 4),
            ortaokul: generateGrades(5, 8),
            lise: generateGrades(9, 12)
        };

        function generateGrades(s, e) {
            let h = `<h4 class="text-white text-center mb-4">Sınıf Seç</h4><div class="row g-2">`;
            for(let i=s; i<=e; i++) h += `<div class="col-6"><button class="wizard-opt" onclick="nextStep('dersler_${i}')">${i}. Sınıf</button></div>`;
            return h + `</div>`;
        }

        function getLessons(grade) {
            const list = ["Matematik", "Türkçe", "Fen Bilimleri", "İngilizce"];
            let h = `<h4 class="text-white text-center mb-4">${grade}. Sınıf Dersleri</h4>`;
            list.forEach(l => h += `<button class="wizard-opt" onclick="completeWizard('${grade}. Sınıf ${l}')">${l}</button>`);
            return h;
        }

        function startLearningFlow() {
            stepHistory = [];
            contentArea().innerHTML = steps.main;
            document.getElementById('ai-wizard-modal').style.display = 'flex';
        }

        function nextStep(key) {
            stepHistory.push(contentArea().innerHTML);
            document.getElementById('wizard-back-btn').style.display = 'block';
            if(key.startsWith('dersler_')) {
                contentArea().innerHTML = getLessons(key.split('_')[1]);
            } else {
                contentArea().innerHTML = steps[key];
            }
        }

        function goBack() {
            contentArea().innerHTML = stepHistory.pop();
            if(stepHistory.length === 0) document.getElementById('wizard-back-btn').style.display = 'none';
        }

        function closeWizard() { document.getElementById('ai-wizard-modal').style.display = 'none'; }

        function completeWizard(topic) {
            // Backend'e yönlendirme ve veriyi URL ile gönderme
            window.location.href = "/Dashboard/Index?selectedTopic=" + encodeURIComponent(topic);
        }

        function goToStudy(topic, unit) {
            window.location.href = "/Dashboard/Study?topic=" + encodeURIComponent(topic) + "&unit=" + unit;
        }
    </script>
}