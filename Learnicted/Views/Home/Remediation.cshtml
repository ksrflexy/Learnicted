<div class="container py-5 text-white" style="margin-top:50px;">
    <div id="remediation-content">
        <h2 id="rem-title" class="fw-bold text-warning mb-4">Hazırlanıyor...</h2>

        <div class="row">
            <div class="col-lg-7">
                <div class="ratio ratio-16x9 mb-4 shadow">
                    <iframe id="rem-video" src="" allowfullscreen class="rounded-3 border-0" style="background: #000;"></iframe>
                </div>
                <div id="rem-summary" class="p-4 bg-dark rounded border border-secondary shadow-sm mb-4" style="line-height:1.8; min-height: 200px;">
                    <div class="text-center mt-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-secondary">Yapay zeka içeriği oluşturuyor...</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card bg-dark border-primary p-4 shadow">
                    <h5 class="text-primary mb-3"><i class="bi bi-patch-check me-2"></i>Hızlı Pekiştirme</h5>
                    <div id="rem-questions" class="mt-3">
                    </div>
                    <button id="finish-btn" class="btn btn-success w-100 mt-4 shadow" onclick="finishRemediation()" style="display:none;">
                        Eğitimi Tamamla
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const urlParams = new URLSearchParams(window.location.search);
    const topic = urlParams.get('topic');

    $(document).ready(function() {
        if(topic) {
            $('#rem-title').text(topic + " - Telafi Eğitimi");

            fetch(`/AI/GetRemediationData?topic=${encodeURIComponent(topic)}`)
                .then(r => r.json())
                .then(res => {
                    const data = res.aiData;

                    if(res.videoId) {
                        $('#rem-video').attr('src', 'https://www.youtube.com/embed/' + res.videoId);
                    }

                    $('#rem-summary').html(data.summary || data.aiSummary || "Özet hazırlandı.");

                    let qHtml = "";
                    const questions = data.questions || [];

                    if(questions.length > 0) {
                        questions.forEach((q, index) => {
                            let optionsHtml = "";
                            q.options.forEach(opt => {
                                const safeOpt = opt.replace(/'/g, "\\'");
                                const safeAnswer = q.answer.replace(/'/g, "\\'");

                                optionsHtml += `
                                    <button class="btn btn-outline-secondary btn-sm text-start quiz-opt mb-2"
                                            onclick="checkRem(this, '${safeOpt}', '${safeAnswer}')">
                                        ${opt}
                                    </button>`;
                            });

                            qHtml += `
                                <div class="mb-4 border-bottom border-secondary pb-3 question-block">
                                    <p class="small fw-bold text-info">Soru ${index + 1}: ${q.question}</p>
                                    <div class="d-grid gap-1">
                                        ${optionsHtml}
                                    </div>
                                </div>`;
                        });
                        $('#finish-btn').fadeIn();
                    } else {
                        qHtml = "<p class='text-muted text-center'>Pekiştirme sorusu oluşturulamadı.</p>";
                    }
                    $('#rem-questions').html(qHtml);
                })
                .catch(err => {
                    console.error("Hata:", err);
                    $('#rem-title').text("Hata Oluştu");
                    $('#rem-summary').html("<p class='text-danger'>İçerik yüklenemedi.</p>");
                });
        }
    });

    function checkRem(btn, selected, correct) {
        const btnObj = $(btn);
        const parentDiv = btnObj.closest('.d-grid');

        if(selected.trim().toLowerCase() === correct.trim().toLowerCase()) {
            btnObj.addClass('btn-success').removeClass('btn-outline-secondary');
            parentDiv.find('button').attr('disabled', 'disabled');
            btnObj.removeAttr('disabled');
        } else {
            btnObj.addClass('btn-danger').removeClass('btn-outline-secondary');
            btnObj.attr('disabled', 'disabled');
        }
    }

    // Düzenlenen fonksiyon: Veritabanında konuyu bitirir.
    function finishRemediation() {
        if (!topic) return;

        fetch('/AI/CompleteCourse', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(topic)
        })
        .then(response => {
            if (response.ok) {
                alert("Tebrikler! Eksiklerini tamamladın ve profilin güncellendi.");
                window.location.href = "/Home/Profile";
            } else {
                alert("Bir hata oluştu, ilerlemen kaydedilemedi.");
            }
        })
        .catch(error => {
            console.error("Hata:", error);
            alert("Sunucuyla bağlantı kurulamadı.");
        });
    }
</script>