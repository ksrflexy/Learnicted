@{
    ViewData["Title"] = "Dashboard";
}

<div class="learnicted-dashboard container-fluid">
    <div id="onboarding-screen" class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 80vh;">
        <div class="glass-card p-5 shadow-lg" style="max-width: 600px; border-radius: 24px;">
            <div class="mb-4">
                <i class="bi bi-rocket-takeoff-fill" style="font-size: 4rem; color: var(--accent); filter: drop-shadow(0 0 15px var(--accent-glow));"></i>
            </div>
            <h1 class="display-6 fw-bold text-white mb-3">Geleceği Keşfet!</h1>
            <p class="text-white-50 fs-5 mb-5">Henüz aktif bir eğitimin yok. AI ile sana özel bir müfredat hazırlamak için aşağıdaki butona tıkla.</p>

            <button class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold"
                    style="background:var(--accent); border:none; box-shadow: 0 10px 30px var(--accent-glow);"
                    onclick="startLearningFlow()">
                <i class="bi bi-magic me-2"></i> Eğitimi Oluşturmaya Başla
            </button>
        </div>
    </div>

    <div id="ai-wizard-modal" class="wizard-overlay" style="display: none;">
        <div class="wizard-card glass-card position-relative">
            <button id="wizard-back-btn" class="btn btn-link text-white-50 position-absolute start-0 top-0 mt-3 ms-3"
                    style="display: none; text-decoration: none;" onclick="goBack()">
                <i class="bi bi-chevron-left"></i> Geri
            </button>

            <div id="wizard-main-container">
                <div class="wizard-header text-center mb-4">
                    <div class="wizard-icon-circle">
                        <i class="bi bi-magic"></i>
                    </div>
                    <h3 class="fw-bold text-white mt-3">Eğitim Sihirbazı</h3>
                    <p class="text-white-50 small">Hedefini belirle, AI dersini hazırlasın.</p>
                </div>

                <div class="wizard-body">
                    <div id="step-content">
                        <div class="step-indicator d-flex justify-content-center gap-2 mb-4">
                            <span class="dot active"></span>
                            <span class="dot"></span>
                            <span class="dot"></span>
                        </div>
                        <h5 class="text-white mb-3 text-center">Ne öğrenmek istersin?</h5>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('yazilim')">
                                <i class="bi bi-code-slash me-2 text-primary"></i> Yazılım Geliştirme
                            </button>
                            <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('okul')">
                                <i class="bi bi-book-half me-2 text-warning"></i> Okul Dersleri (İlkokul-Lise)
                            </button>
                            <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('dil')">
                                <i class="bi bi-translate me-2 text-info"></i> Yabancı Dil
                            </button>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button class="btn btn-link text-white-50 btn-sm" onclick="closeWizard()">Vazgeç</button>
                </div>
            </div>
        </div>
    </div>

    <div id="main-content-area" style="display: none;">
        <div id="section-panel" class="nav-section">
            <h3 class="text-white fw-bold mb-4" id="selected-course-title">Ders Yükleniyor...</h3>
            <div class="glass-card p-4">Panel içeriği burada görünecek...</div>
        </div>
    </div>
</div>

<style>
    .wizard-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(10,15,28,0.95);
        backdrop-filter: blur(15px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .wizard-card {
        width: 100%;
        max-width: 480px;
        padding: 40px !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 30px !important;
        background: rgba(30, 41, 59, 0.7) !important;
    }

    .wizard-opt {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        transition: 0.3s;
        color: white !important;
        display: flex;
        align-items: center;
    }

        .wizard-opt img {
            width: 20px;
            margin-right: 12px;
            border-radius: 2px;
        }

        .wizard-opt:hover {
            background: rgba(255, 255, 255, 0.05) !important;
            border-color: var(--accent) !important;
            transform: translateX(8px);
        }

    .dot {
        width: 10px;
        height: 10px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
    }

        .dot.active {
            background: var(--accent);
        }

    .wizard-icon-circle {
        width: 60px;
        height: 60px;
        background: var(--accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        color: white;
        font-size: 1.5rem;
    }
</style>

<script>
    let stepHistory = []; // Geri tuşu için geçmişi tutan dizi

    function startLearningFlow() {
        stepHistory = []; // Geçmişi sıfırla
        document.getElementById('wizard-back-btn').style.display = 'none';
        document.getElementById('ai-wizard-modal').style.display = 'flex';
    }

    function closeWizard() { document.getElementById('ai-wizard-modal').style.display = 'none'; }

    function goBack() {
        if (stepHistory.length > 0) {
            const lastStep = stepHistory.pop();
            document.getElementById('step-content').innerHTML = lastStep;
            if (stepHistory.length === 0) {
                document.getElementById('wizard-back-btn').style.display = 'none';
            }
        }
    }

    function nextStep(type) {
        const content = document.getElementById('step-content');
        stepHistory.push(content.innerHTML); // Mevcut ekranı geçmişe kaydet
        document.getElementById('wizard-back-btn').style.display = 'block';

        let html = `<div class="step-indicator d-flex justify-content-center gap-2 mb-4"><span class="dot active"></span><span class="dot active"></span><span class="dot"></span></div>`;

        if(type === 'yazilim') {
            html += `<h5 class="text-white mb-3 text-center">Hangi dil?</h5><div class="d-grid gap-2">
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('Python')">🐍 Python</button>
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('C#')">🛡️ C# .NET</button>
            </div>`;
        } else if(type === 'okul') {
            html += `<h5 class="text-white mb-3 text-center">Eğitim Kademesi?</h5><div class="d-grid gap-2">
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('ilkokul')">🎒 İlkokul</button>
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('ortaokul')">📘 Ortaokul</button>
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="nextStep('lise')">🎓 Lise</button>
            </div>`;
        } else if(type === 'ilkokul' || type === 'ortaokul' || type === 'lise') {
            const titles = { ilkokul: 'İlkokul', ortaokul: 'Ortaokul', lise: 'Lise' };
            html += `<h5 class="text-white mb-3 text-center">${titles[type]} Sınıf Seçin</h5><div class="d-grid gap-2">`;
            const count = type === 'ilkokul' ? 4 : 4;
            const start = type === 'ilkokul' ? 1 : (type === 'ortaokul' ? 5 : 9);
            for(let i=start; i<(start+4); i++) {
                html += `<button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('${i}. Sınıf Dersleri')">${i}. Sınıf</button>`;
            }
            html += `</div>`;
        } else if(type === 'dil') {
            // BAYRAKLARI SVG OLARAK DÜZELTTİK
            html += `<h5 class="text-white mb-3 text-center">Hangi Dil?</h5><div class="d-grid gap-2">
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('İngilizce')">
                    <img src="https://flagcdn.com/w40/gb.png"> İngilizce
                </button>
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('Almanca')">
                    <img src="https://flagcdn.com/w40/de.png"> Almanca
                </button>
                <button class="btn btn-outline-light text-start p-3 wizard-opt" onclick="completeWizard('Fransızca')">
                    <img src="https://flagcdn.com/w40/fr.png"> Fransızca
                </button>
            </div>`;
        }
        content.innerHTML = html;
    }

    function completeWizard(name) {
        document.getElementById('wizard-back-btn').style.display = 'none';
        const container = document.getElementById('wizard-main-container');
        container.innerHTML = `<div class="text-center py-5"><div class="spinner-border text-primary mb-3" role="status"></div><h4 class="text-white">${name} Hazırlanıyor...</h4></div>`;

        setTimeout(() => {
            closeWizard();
            document.getElementById('onboarding-screen').style.display = 'none';
            document.getElementById('main-content-area').style.display = 'block';
            document.getElementById('selected-course-title').innerText = name + " Yolculuğu";
        }, 2000);
    }
</script>