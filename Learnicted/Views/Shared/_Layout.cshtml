<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Learnicted</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --accent: #6366f1;
            --accent-glow: rgba(99, 102, 241, 0.3);
            --card-bg: rgba(30, 41, 59, 0.7);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0f172a;
            color: #ffffff;
            margin: 0;
            overflow-x: hidden;
        }

        #dynamicBg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background-size: cover;
            background-position: center;
            transition: opacity 0.8s ease-in-out;
            pointer-events: none;
        }

        .theme-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.7) 0%, #0f172a 100%);
            backdrop-filter: blur(12px);
        }

        .sidebar {
            width: 280px;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(25px);
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            position: fixed;
            height: 100vh;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            width: calc(100% - 280px);
            min-height: 100vh;
        }

        .no-sidebar {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .sidebar-label {
            font-size: 0.7rem;
            font-weight: 800;
            color: #818cf8;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 25px 30px 10px;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.7) !important;
            font-weight: 600;
            padding: 12px 25px !important;
            margin: 4px 15px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            transition: all 0.3s;
            text-decoration: none;
        }

            .nav-link:hover, .nav-link.active {
                background: var(--accent);
                color: white !important;
                box-shadow: 0 10px 20px var(--accent-glow);
            }

        .profile-section {
            padding: 20px;
            margin: 10px 15px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .avatar-plus {
            position: relative;
            padding: 3px;
            background: linear-gradient(45deg, #6366f1, #f472b6, #6366f1);
            background-size: 200% 200%;
            animation: borderRotate 3s linear infinite;
        }

        @@keyframes borderRotate {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .theme-drawer {
            background: rgba(0, 0, 0, 0.3);
            margin: 10px 15px;
            padding: 15px;
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .theme-list {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            max-height: 150px;
            overflow-y: auto;
        }

        .theme-mini-card {
            aspect-ratio: 1;
            border-radius: 8px;
            cursor: pointer;
            background-size: cover;
            background-position: center;
            border: 2px solid transparent;
            transition: 0.2s;
        }

            .theme-mini-card:hover {
                transform: scale(1.1);
                border-color: var(--accent);
            }

        .premium-badge {
            background: linear-gradient(45deg, #ffd700, #ffa500);
            color: #000;
            font-size: 0.6rem;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 4px;
            vertical-align: middle;
        }

        /* Modal Custom Styling */
        .modal-content.custom-dark {
            background: #0f172a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 30px;
        }

        .plan-card {
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.03);
            transition: 0.3s;
        }

            .plan-card.active {
                border-color: var(--accent);
                background: rgba(99, 102, 241, 0.1);
            }
    </style>
</head>
<body>
    <div id="dynamicBg"></div>
    <div class="theme-overlay"></div>

    @{
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
        var action = ViewContext.RouteData.Values["Action"]?.ToString();
        bool isAuthPage = controller == "Account" && (action == "Login" || action == "Register");

        // SENKRONİZASYON: ViewBag verisi yoksa Identity'den çek
        string fullName = ViewBag.FullName ?? (User.Identity.IsAuthenticated ? User.Identity.Name : "Öğrenci");
        int streak = ViewBag.Streak ?? 0;
        string membershipType = ViewBag.MembershipType ?? "Free"; // Free, Plus, Premium
        bool hasSpecialAccess = membershipType == "Plus" || membershipType == "Premium";
    }

    @if (!isAuthPage)
    {
        <div class="sidebar">
            <div class="profile-section text-center mt-3">
                <div class="avatar-wrapper mb-2 position-relative d-inline-block @(hasSpecialAccess ? "avatar-plus rounded-circle" : "")">
                    @{
                        // Eğer Plus veya Premium ise hareketli avatar, değilse UI Avatar
                        string avatarUrl = hasSpecialAccess
                        ? "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJueXF6bm9ueXF6bm9ueXF6bm9ueXF6bm9ueXF6bm9ueXF6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/3o7TKMGpxx66HeT0pW/giphy.gif"
                        : $"https://ui-avatars.com/api/?name={fullName}&background=6366f1&color=fff";
                    }
                    <img src="@avatarUrl" class="rounded-circle border border-2 border-primary shadow-lg" style="width: 65px; height: 65px; object-fit: cover;">
                </div>
                <h6 class="fw-bold text-white mb-0">
                    @fullName
                    @if (membershipType == "Plus")
                    {
                        <span class="text-info">✨</span>
                    }
                    else if (membershipType == "Premium")
                    {

                        <span class="premium-badge">PREMIUM</span>
                    }
                </h6>
                <div class="d-flex justify-content-center gap-1 mt-2">
                    <span class="badge bg-danger p-1 px-2" style="font-size: 0.65rem;">🔥 @streak GÜN</span>
                    <span class="badge bg-primary p-1 px-2" style="font-size: 0.65rem;">🏆 LİG #12</span>
                </div>
                <a href="/Home/Profile" class="btn btn-sm btn-outline-light w-100 rounded-pill mt-3 border-opacity-25" style="font-size: 0.75rem;">
                    <i class="bi bi-person-gear me-1"></i> Profili Yönet
                </a>
            </div>

            <div class="sidebar-label">ÖĞRENİM MERKEZİ</div>
            <nav class="flex-grow-1">
                <a href="/Dashboard/Index" class="nav-link @(controller == "Dashboard" && action == "Index" ? "active" : "")">
                    <i class="bi bi-grid-fill me-3"></i> Panel
                </a>
                <a href="/Dashboard/Roadmap" class="nav-link @(controller == "Dashboard" && action == "Roadmap" ? "active" : "")">
                    <i class="bi bi-map-fill me-3"></i> Yol Haritası
                </a>
                <a href="/Dashboard/Study" class="nav-link @(controller == "Dashboard" && action == "Study" ? "active" : "")">
                    <i class="bi bi-book-half me-3"></i> Çalışma Alanı
                </a>
                <a href="/Course/Index" class="nav-link @(controller == "Course" ? "active" : "")">
                    <i class="bi bi-play-circle-fill me-3"></i> Video Dersler
                </a>
            </nav>

            <div class="sidebar-label">TEMALAR</div>
            <div class="theme-drawer position-relative">
                @if (!hasSpecialAccess)
                {
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center rounded-3" style="background: rgba(0,0,0,0.7); z-index: 5; backdrop-filter: blur(2px);">
                        <small class="text-white fw-bold" style="font-size: 0.6rem;"><i class="bi bi-lock-fill me-1"></i> PLUS GEREKLİ</small>
                    </div>
                }
                <div class="theme-list">
                    <div class="theme-mini-card" style="background:#1e293b; border: 1px solid rgba(255,255,255,0.2)" onclick="setTheme('default', '#6366f1')"></div>
                    <div class="theme-mini-card" style="background-image:url('/assets/themes/spiderman.gif')" onclick="setTheme('spiderman', '#e63946')"></div>
                    <div class="theme-mini-card" style="background-image:url('/assets/themes/naruto.gif')" onclick="setTheme('naruto', '#ff9800')"></div>
                    <div class="theme-mini-card" style="background-image:url('/assets/themes/cyberpunk.gif')" onclick="setTheme('cyberpunk', '#00ffcc')"></div>
                </div>
            </div>

            <div class="p-3 mb-4">
                <div class="upgrade-card-new p-3" style="background: linear-gradient(135deg, #6366f1, #a855f7); border-radius: 20px;">
                    <button type="button" class="btn btn-light btn-sm w-100 rounded-pill fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#upgradeModal">
                        @(membershipType == "Free" ? "Plus'a Geç" : "Planı Yönet")
                    </button>
                </div>
                <a href="/Account/Login" class="nav-link mt-2 text-danger" style="font-size:0.85rem;"><i class="bi bi-box-arrow-right me-3"></i> Çıkış</a>
            </div>
        </div>
    }

    <div class="modal fade" id="upgradeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content custom-dark text-white p-4">
                <div class="modal-header border-0">
                    <h3 class="fw-800">Üyeliğini Yükselt</h3>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="plan-card p-4 rounded-4 h-100 @(membershipType == "Free" ? "active" : "")">
                                <h4 class="fw-bold">Ücretsiz</h4>
                                <h2 class="fw-800 mb-4">$0 <small class="fs-6 text-white-50">/ay</small></h2>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i> Günlük 100 Soru</li>
                                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i> Günlük 15 AI Sorusu</li>
                                    <li class="mb-2 text-white-50"><i class="bi bi-x text-danger me-2"></i> Hareketli Avatar</li>
                                    <li class="mb-2 text-white-50"><i class="bi bi-x text-danger me-2"></i> Tema Özelleştirme</li>
                                </ul>
                                <button class="btn btn-outline-light w-100 rounded-pill mt-4 disabled">Mevcut Plan</button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="plan-card p-4 rounded-4 h-100 border-primary @(membershipType == "Plus" ? "active" : "")" style="background: rgba(99, 102, 241, 0.05);">
                                <div class="badge bg-primary mb-2">POPÜLER</div>
                                <h4 class="fw-bold">Learnicted Plus</h4>
                                <h2 class="fw-800 mb-4">$8 <small class="fs-6 text-white-50">/ay</small></h2>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> Günlük 1000 Soru</li>
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> Sınırsız AI Sorusu</li>
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> 2X XP Çarpanı</li>
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> Hareketli Avatar</li>
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> Tema Özelleştirme</li>
                                </ul>
                                <button class="btn btn-primary w-100 rounded-pill mt-4 fw-bold">Şimdi Yükselt</button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="plan-card p-4 rounded-4 h-100 @(membershipType == "Premium" ? "active" : "")" style="border: 1px solid #ffd700;">
                                <h4 class="fw-bold text-warning">Premium</h4>
                                <h2 class="fw-800 mb-4">$15 <small class="fs-6 text-white-50">/ay</small></h2>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-star-fill text-warning me-2"></i> Her Şey Sınırsız</li>
                                    <li class="mb-2"><i class="bi bi-star-fill text-warning me-2"></i> Tüm Plus Özellikleri</li>
                                    <li class="mb-2"><i class="bi bi-star-fill text-warning me-2"></i> Öncelikli Destek</li>
                                    <li class="mb-2"><i class="bi bi-star-fill text-warning me-2"></i> Erken Erişim</li>
                                </ul>
                                <button class="btn btn-warning w-100 rounded-pill mt-4 fw-bold">Premium'a Geç</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content @(isAuthPage ? "no-sidebar" : "")">
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Üyelik durumunu JS'e aktaralım
        const isSpecialMember = @(hasSpecialAccess.ToString().ToLower());

        function setTheme(name, color) {
            if(!isSpecialMember && name !== 'default') {
                alert("Tema özelleştirme sadece PLUS üyeler içindir!");
                return;
            }

            const bg = document.getElementById('dynamicBg');
            const path = name === 'default' ? '' : `/assets/themes/${name}.gif`;
            if(bg) {
                bg.style.opacity = "0";
                setTimeout(() => {
                    bg.style.backgroundImage = path ? `url('${path}')` : 'none';
                    bg.style.opacity = "1";
                }, 400);
            }
            document.documentElement.style.setProperty('--accent', color);
            localStorage.setItem('theme-pref', name);
            localStorage.setItem('accent-pref', color);
        }

        document.addEventListener("DOMContentLoaded", () => {
            const savedTheme = localStorage.getItem('theme-pref') || 'default';
            const savedColor = localStorage.getItem('accent-pref') || '#6366f1';

            // Eğer kullanıcı plus değilse ama localde tema kalmışsa default'a çek
            if(!isSpecialMember) {
                setTheme('default', '#6366f1');
            } else {
                setTheme(savedTheme, savedColor);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>